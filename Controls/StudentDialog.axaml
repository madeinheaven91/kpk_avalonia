<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="kpk_avalonia.StudentDialog"
        Title="Dialog">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Имя"/>
    <TextBox x:Name="TxtFirstName"/>
    <TextBlock Text="Фамилия"/>
    <TextBox x:Name="TxtLastName"/>
    <TextBlock Text="Отчество"/>
    <TextBox x:Name="TxtPatronymic"/>
	<WrapPanel Margin="0 0 0 5">
		<TextBlock Text="Группа:" Margin="0 0 17 0"/>
		<ComboBox Width="100" x:Name="CmbxGroup" SelectionChanged="CmbxGroup_SelectionChanged" Margin="0 0 15 0">
			<ComboBox.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding Number}"/>
				</DataTemplate>
			</ComboBox.ItemTemplate>
		</ComboBox>
	</WrapPanel>
	<WrapPanel Margin="0 0 0 5">
		<TextBlock Text="Д/Р:" Margin="0 0 35 0"/>
		<DatePicker x:Name="DpBirthday"/>
	</WrapPanel>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Content="Сохранить" Click="BtnSave_Click"/>
      <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
  </StackPanel>
</Window>
