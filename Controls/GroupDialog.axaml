<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="kpk_avalonia.GroupDialog"
        Title="Группа"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Номер группы"/>
    <TextBox x:Name="TxtNumber"/>
    <TextBlock Text="Описание"/>
    <TextBox x:Name="TxtDescription" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
    <WrapPanel Margin="0 0 0 5">
      <TextBlock Text="Специальность:" Margin="0 0 10 0" VerticalAlignment="Center"/>
      <ComboBox Width="200" x:Name="CmbxSpecialty">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </WrapPanel>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Content="Сохранить" Click="BtnSave_Click"/>
      <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
  </StackPanel>
</Window>
